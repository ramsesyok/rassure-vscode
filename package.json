{
  "name": "rassure-vscode",
  "displayName": "Rassure",
  "description": "ローカル駆動・データベースレスの課題管理用VS Code拡張",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ramsesyok/rassure-vscode"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rassure-vscode.openBoard",
        "title": "Rassure: ボードを開く"
      },
      {
        "command": "rassure-vscode.exportToExcel",
        "title": "Rassure: Excel にエクスポート"
      }
    ],
    "configuration": {
      "title": "Rassure",
      "properties": {
        "rassure-vscode.username": {
          "type": "string",
          "default": "",
          "description": "チケットに記録するユーザー名（未設定時はOSのユーザー名を使用します）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p tsconfig.json",
    "build": "npm run compile && npm run build:webview",
    "build:webview": "vite build",
    "watch": "tsc -p tsconfig.json --watch",
    "watch:webview": "vite build --watch",
    "pretest": "npm run compile",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/react": "^18.x",
    "@types/react-dom": "^18.x",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.x",
    "typescript": "^5.x",
    "vite": "^5.x"
  },
  "dependencies": {
    "@emotion/react": "^11.x",
    "@emotion/styled": "^11.x",
    "@fontsource/roboto": "^5.x",
    "@mui/icons-material": "^6.x",
    "@mui/material": "^6.x",
    "dayjs": "^1.x",
    "exceljs": "^4.4.0",
    "react": "^18.x",
    "react-dom": "^18.x"
  }
}