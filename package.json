{
  "name": "rassure-vscode",
  "displayName": "Rassure",
  "description": "ローカル駆動・データベースレスの課題管理用VS Code拡張",
  "version": "0.2.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ramsesyok/rassure-vscode"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rassure-vscode.openBoard",
        "title": "Rassure: ボードを開く"
      },
      {
        "command": "rassure-vscode.exportToExcel",
        "title": "Rassure: Excel にエクスポート"
      }
    ],
    "configuration": {
      "title": "Rassure",
      "properties": {
        "rassure-vscode.username": {
          "type": "string",
          "default": "",
          "description": "チケットに記録するユーザー名（未設定時はOSのユーザー名を使用します）"
        },
        "rassure-vscode.idPrefix": {
          "type": "string",
          "default": "#",
          "maxLength": 5,
          "pattern": "^[^\\\\/:*?\"<>|]+$",
          "description": "チケットIDおよびファイル名の先頭に付与するプレフィックスを指定します。OSのファイル名禁止文字（\\ / : * ? \" < > |）は使用できません。"
        },
        "rassure-vscode.exportColumnOrder": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["ID","状況","重要度","指摘対象","指摘種別","説明","コメント","指摘者","担当者","期限","作成日","更新日"],
          "description": "Excelエクスポート時のカラムの並び順を指定します。出力したい項目を上から順に並べてください。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p tsconfig.json --noEmit",
    "build:extension": "esbuild src/extension/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs",
    "build": "npm run build:extension && npm run build:webview",
    "build:webview": "vite build",
    "watch": "esbuild src/extension/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --watch",
    "watch:webview": "vite build --watch",
    "pretest": "npm run build:extension",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/react": "^18.x",
    "@types/react-dom": "^18.x",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.x",
    "esbuild": "^0.28.0",
    "typescript": "^5.x",
    "vite": "^5.x"
  },
  "dependencies": {
    "@emotion/react": "^11.x",
    "@emotion/styled": "^11.x",
    "@fontsource/roboto": "^5.x",
    "@mui/icons-material": "^6.x",
    "@mui/material": "^6.x",
    "dayjs": "^1.x",
    "exceljs": "^4.4.0",
    "react": "^18.x",
    "react-dom": "^18.x"
  }
}